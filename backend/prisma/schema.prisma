generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// сотрудники (флористы и Владелец)
model User {
  id        Int      @id @default(autoincrement())
  name      String
  pin       String   @unique // хэшированный smart пин-код для входа
  role      String   @default("FLORIST") // Роли: ADMIN или FLORIST
  createdAt DateTime @default(now())
}

// клиенты магазина (для программы лояльности)
model Client {
  id          Int           @id @default(autoincrement())
  name        String?       // необязательно
  phone       String        @unique
  ordersCount Int           @default(0) // заказы для системы лояльности

  orders      Order[]
  events      ClientEvent[]

  createdAt   DateTime      @default(now())
}

// Поводы для покупки (Дни рождения близких, годовщины)
model ClientEvent {
  id          Int      @id @default(autoincrement())
  title       String   // "День рождения мамы", "Годовщина"
  date        DateTime

  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id])
}

// склад (цветы, упаковка, ленты, услуги)
model Item {
  id          Int         @id @default(autoincrement())
  name        String
  category    String      // 'FLOWER', 'PACKAGING', 'SERVICE'
  quantity    Int         @default(0)
  costPrice   Int         @default(0) // NEW: Себестоимость
  price       Int         @default(0) // цена за 1 штуку

  // связи
  orderItems      OrderItem[]
  usedInBouquets  BouquetIngredient[] // связь: в каких шаблонах букетов используется
}

// NEW: Шаблон Букета (Витринный образец / карта)
model BouquetTemplate {
  id          Int      @id @default(autoincrement())
  name        String   // "Букет Нежность", "101 Роза"
  price       Int      // Итоговая розничная цена продажи этого букета

  ingredients   BouquetIngredient[]
  orderBouquets OrderBouquet[]      // связь с проданными букетами
}

// NEW: Ингредиенты рецепта (Состав шаблона букета)
model BouquetIngredient {
  id                Int      @id @default(autoincrement())
  quantity          Int      // Количество (например, 15 роз)

  bouquetTemplateId Int
  bouquetTemplate   BouquetTemplate @relation(fields: [bouquetTemplateId], references: [id])

  itemId            Int
  item              Item     @relation(fields: [itemId], references: [id])
}

// заказы
model Order {
  id          Int         @id @default(autoincrement())
  totalPrice  Int
  source      String      // 'INSTAGRAM', 'WHATSAPP', '2GIS', 'WALK_IN'
  status      String      @default("COMPLETED") // 'PENDING', 'COMPLETED', 'CANCELLED'

  clientId    Int?        // ссылка на клиента (может быть пустым)
  client      Client?     @relation(fields: [clientId], references: [id])

  // NEW: состав заказа теперь делится на поштучные товары и готовые букеты
  items       OrderItem[]
  bouquets    OrderBouquet[]

  createdAt   DateTime    @default(now())
}

// состав заказа (промежуточная таблица для списания поштучного товара)
model OrderItem {
  id          Int   @id @default(autoincrement())

  orderId     Int
  order       Order @relation(fields: [orderId], references: [id])

  itemId      Int
  item        Item  @relation(fields: [itemId], references: [id])

  quantity    Int   // (например, 15 роз)
  priceAtSale Int   // фиксируем цену на момент продажи
}

// NEW: Промежуточная таблица для проданных букетов в заказе
model OrderBouquet {
  id                Int      @id @default(autoincrement())
  quantity          Int      // Сколько таких одинаковых букетов купили
  priceAtSale       Int      // Фиксируем цену букета на момент продажи

  orderId           Int
  order             Order    @relation(fields: [orderId], references: [id])

  bouquetTemplateId Int
  bouquetTemplate   BouquetTemplate @relation(fields: [bouquetTemplateId], references: [id])
}